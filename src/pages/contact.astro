---
import Layout from '../layouts/Layout.astro';

const orderOptions = [
  'Less than 50 orders/day',
  '50–200 orders/day',
  '200–500 orders/day',
  '500+ orders/day',
];

const platformOptions = [
  'Amazon',
  'Bol.com',
  'Both Amazon & Bol.com',
  'Other',
];

const nextSteps = [
  { step: '1', title: 'We review your submission', desc: 'Within 24 hours, max.' },
  { step: '2', title: '5-question prep form', desc: "We send you a short form to understand your current workflow before the call." },
  { step: '3', title: 'Discovery call', desc: '20 minutes, no sales pitch.' },
  { step: '4', title: 'Custom proposal', desc: "We send a tailored proposal within 48 hours of the call." },
  { step: '5', title: 'You decide', desc: 'No pressure. No hard sell.' },
];
---

<Layout title="Contact & Book a Call — AgentleConsulting"
  description="Tell us where you're stuck, or book a time that works. We respond to every inquiry within 24 hours.">

  <!-- HERO -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-site max-w-3xl">
      <p class="section-label">Get In Touch</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-slate mb-6">Let's See If We Can Help</h1>
      <p class="text-lg text-slate/60 leading-relaxed">
        Tell us where you're stuck, or book a time that works. We respond to every inquiry within 24 hours.
      </p>
    </div>
  </section>

  <!-- CALENDLY + FORM -->
  <section class="bg-stone py-16 md:py-24">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- LEFT: Calendly -->
        <div class="bg-white rounded-2xl p-8 border border-stone">
          <h2 class="font-heading font-bold text-2xl text-slate mb-2">Pick a Time</h2>
          <p class="text-sm text-slate/50 mb-6">20-minute discovery call — no commitment.</p>

          <!-- Calendly embed placeholder -->
          <div class="bg-stone rounded-xl p-12 text-center min-h-[400px] flex flex-col items-center justify-center">
            <svg class="w-12 h-12 text-sage mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <p class="font-heading font-bold text-slate mb-2">Calendly Embed</p>
            <p class="text-sm text-slate/50 mb-4">Replace <code class="font-mono text-xs bg-cream px-1">YOUR_CALENDLY_USERNAME</code> with your actual Calendly username</p>
            <a href="https://calendly.com/YOUR_CALENDLY_USERNAME/discovery-call"
               target="_blank" rel="noopener noreferrer"
               class="btn-primary text-sm">
              Open Calendly ↗
            </a>
            <!-- Actual embed (uncomment and replace username when ready) -->
            <!--
            <div class="calendly-inline-widget"
                 data-url="https://calendly.com/YOUR_CALENDLY_USERNAME/discovery-call"
                 style="min-width:320px;height:630px;">
            </div>
            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
            -->
          </div>

          <p class="text-xs text-slate/40 mt-4 text-center">
            No commitment. We'll ask about your workflow, you decide if we're worth it.
          </p>
        </div>

        <!-- RIGHT: Contact Form -->
        <div class="bg-white rounded-2xl p-8 border border-stone">
          <h2 class="font-heading font-bold text-2xl text-slate mb-2">Or Send Us a Message</h2>
          <p class="text-sm text-slate/50 mb-6">We reply within 24 hours, usually much faster.</p>

          <form id="contact-form" class="space-y-5" novalidate>
            <div>
              <label for="name" class="block text-sm font-medium text-slate mb-1.5">Full Name</label>
              <input type="text" id="name" name="name" required
                     class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate placeholder-slate/30 focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors"
                     placeholder="Your name" />
            </div>

            <div>
              <label for="business" class="block text-sm font-medium text-slate mb-1.5">Business Name</label>
              <input type="text" id="business" name="business"
                     class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate placeholder-slate/30 focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors"
                     placeholder="Your company or brand name" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate mb-1.5">Email Address</label>
              <input type="email" id="email" name="email" required
                     class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate placeholder-slate/30 focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors"
                     placeholder="you@example.com" />
            </div>

            <div>
              <label for="orders" class="block text-sm font-medium text-slate mb-1.5">Monthly Orders</label>
              <select id="orders" name="orders"
                      class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors appearance-none cursor-pointer">
                <option value="">Select order volume</option>
                {orderOptions.map(opt => <option value={opt}>{opt}</option>)}
              </select>
            </div>

            <div>
              <label for="platform" class="block text-sm font-medium text-slate mb-1.5">Main Platform</label>
              <select id="platform" name="platform"
                      class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors appearance-none cursor-pointer">
                <option value="">Select platform</option>
                {platformOptions.map(opt => <option value={opt}>{opt}</option>)}
              </select>
            </div>

            <div>
              <label for="pain" class="block text-sm font-medium text-slate mb-1.5">Biggest Pain Point</label>
              <textarea id="pain" name="pain" rows="4" required
                        class="w-full px-4 py-2.5 bg-cream border border-stone rounded-lg text-sm text-slate placeholder-slate/30 focus:outline-none focus:ring-2 focus:ring-sage/40 focus:border-sage transition-colors resize-none"
                        placeholder="Tell us where you're stuck — the task that eats your time, the bottleneck that never resolves..."></textarea>
            </div>

            <div id="form-error" class="hidden text-sm text-red-500"></div>

            <button type="submit" class="btn-primary w-full justify-center text-base py-3">
              Send Message →
            </button>

            <p class="text-xs text-slate/40 text-center">
              We'll reply within 24 hours. No spam, no newsletters without consent.
            </p>
          </form>

          <!-- Success state (hidden by default) -->
          <div id="form-success" class="hidden text-center py-8">
            <svg class="w-12 h-12 text-sage mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <h3 class="font-heading font-bold text-xl text-slate mb-2">Message Sent!</h3>
            <p class="text-sm text-slate/60">We'll get back to you within 24 hours. Check your inbox.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-site">
      <h2 class="font-heading font-bold text-3xl text-slate mb-12">What Happens Next</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
        {nextSteps.map(s => (
          <div class="relative">
            <div class="bg-white rounded-2xl p-6 border border-stone h-full">
              <div class="w-8 h-8 bg-sage rounded-full flex items-center justify-center text-pearl font-bold text-sm mb-4">{s.step}</div>
              <h3 class="font-heading font-bold text-base text-slate mb-1">{s.title}</h3>
              <p class="text-xs text-slate/50 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorDiv) errorDiv.classList.add('hidden');

    const data = new FormData(form);
    // Client-side validation
    const name = data.get('name') as string;
    const email = data.get('email') as string;
    const pain = data.get('pain') as string;

    if (!name?.trim() || !email?.trim() || !pain?.trim()) {
      if (errorDiv) {
        errorDiv.textContent = 'Please fill in all required fields.';
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (errorDiv) {
        errorDiv.textContent = 'Please enter a valid email address.';
        errorDiv.classList.remove('hidden');
      }
      return;
    }

    // Simulate submission (replace with actual endpoint)
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      // TODO: Wire to actual form endpoint (Netlify Forms, Formspree, etc.)
      await new Promise(resolve => setTimeout(resolve, 800));
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      if (errorDiv) {
        errorDiv.textContent = 'Something went wrong. Please try again or email us directly at hello@agentleconsulting.com.';
        errorDiv.classList.remove('hidden');
      }
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    }
  });
</script>
