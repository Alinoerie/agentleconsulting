---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    quote: "Agentle found bottlenecks in our operation we didn't know we had. We thought we were efficient. Turns out we were just used to being slow.",
    author: "Marco T.",
    role: "Amazon Kitchenware Seller",
    location: "Germany",
  },
  {
    quote: "First workflow was live in 4 days. I'd been trying to solve that problem for 8 months on my own. This feels like cheating.",
    author: "Lena V.",
    role: "Bol.com Home Goods Seller",
    location: "Netherlands",
  },
  {
    quote: "I took a real vacation for the first time in 3 years. My automations handled everything while I was gone. I came back relaxed.",
    author: "Pieter J.",
    role: "Multi-Channel Amazon Seller",
    location: "Belgium",
  },
];

const problems = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "20 Hours a Week in Admin Work",
    problem: "Every morning starts with a pile of orders, inventory updates, and customer messages that should've been handled automatically.",
    solution: "Order processing, inventory sync, and customer updates that run while you sleep — so your mornings start clear.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Competitors Outpricing You While You Sleep",
    problem: "Your competitor drops €0.05 and you're losing the buy box. You can't watch repricing wars 24/7.",
    solution: "24/7 repricing automation that monitors the market and adjusts within seconds — protecting your margins without you lifting a finger.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    title: "Financial Surprises That Kill Cash Flow",
    problem: "Storage fees, referral fees, advertising costs — all in separate dashboards. You don't know your real margin until it's too late.",
    solution: "Automated daily financial snapshots that consolidate your true costs, margins, and profitability in one view.",
  },
];

const services = [
  {
    tier: 'Discover',
    price: '€1,500',
    duration: '5 Days',
    tagline: 'Start here if you\'re not sure where to automate first.',
    href: '/services#discover',
    badge: 'START HERE',
    features: ['Full workflow audit', 'Automation roadmap (PDF)', 'Live walkthrough call', 'Technical specs for top 3 automations', '30-day email follow-up'],
  },
  {
    tier: 'Automate',
    price: '€4,500–7,500',
    duration: '2–4 Weeks',
    tagline: 'We build 1–3 core workflows and hand them over live.',
    href: '/services#automate',
    badge: 'MOST POPULAR',
    features: ['Discovery Sprint included', '1–3 workflows built + tested', 'Live demo + handover', 'Documentation (runbook)', '30-day bug-fix SLA'],
  },
  {
    tier: 'Transform',
    price: '€12,000–18,000',
    duration: '6–10 Weeks',
    tagline: 'Your entire Amazon/Bol.com operation — automated.',
    href: '/services#transform',
    badge: 'ENTERPRISE-GRADE',
    features: ['Full operations audit', '6–10 workflows built', 'Cross-platform integration', 'Custom dashboard', '90-day SLA + monthly check-ins'],
  },
];

const blogPosts = [
  {
    title: 'How to Automate Inventory Management on n8n',
    excerpt: 'A step-by-step guide to building a real-time inventory sync between Amazon, Bol.com, and your warehouse using n8n workflows.',
    slug: 'automate-inventory-n8n',
    date: '2026-04-12',
    readTime: '8 min read',
    tag: 'Tutorial',
  },
  {
    title: 'The 5 Amazon Tasks You Should Automate First',
    excerpt: 'Not all automation is equal. These five workflows deliver the biggest ROI for the least setup effort — here\'s the order we recommend.',
    slug: 'amazon-automation-priority',
    date: '2026-03-28',
    readTime: '6 min read',
    tag: 'Guide',
  },
  {
    title: 'Bol.com vs Amazon: Automation Platforms Compared',
    excerpt: 'Both marketplaces have distinct APIs, quirks, and automation opportunities. Here\'s how to approach each one.',
    slug: 'bol-amazon-automation-compared',
    date: '2026-03-10',
    readTime: '10 min read',
    tag: 'Comparison',
  },
];
---

<Layout title="AgentleConsulting — Automation for Amazon & Bol.com Sellers">
  <!-- ===== HERO ===== -->
  <section class="bg-sage text-pearl">
    <div class="container-site py-20 md:py-32">
      <div class="max-w-3xl">
        <!-- Logo mark -->
        <div class="mb-8">
          <svg width="48" height="48" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 28C6 28 12 8 22 10C32 12 30 22 30 22C30 22 28 14 22 14C16 14 18 22 18 22"
                  stroke="#6B9E78" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="26" cy="10" r="3" fill="#D4956A"/>
          </svg>
        </div>

        <h1 class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Your Amazon or Bol.com Business Is Running on<br/>
          <span class="text-amber">Sticky Notes and Spreadsheets.</span>
        </h1>

        <p class="text-lg md:text-xl text-pearl/80 leading-relaxed mb-10 max-w-2xl">
          We build the automation systems that let serious sellers step back — and actually run a business again.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href="/contact" class="btn-primary text-base">
            Book a Free Discovery Call →
          </a>
          <a href="/services" class="btn-outline-dark text-base">
            See How It Works
          </a>
        </div>
        <p class="text-sm text-pearl/50">No commitment. 20 minutes. Find out if we can help in the first call.</p>
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL PROOF BAR ===== -->
  <section class="bg-stone py-8 border-y border-stone/80">
    <div class="container-site">
      <p class="text-center text-sm font-medium text-slate/60 mb-6">
        Trusted by 30+ Amazon and Bol.com sellers across the Netherlands, Belgium, and Germany
      </p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-40">
        <!-- Placeholder logos as styled text blocks -->
        {['Seller Co.', 'GrowBrand', 'ScaleUp BV', 'EuroGoods', 'Nordic Sell', 'Benelux Store'].map(name => (
          <span class="font-heading font-bold text-slate text-sm tracking-wider uppercase">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-site">
      <div class="text-center mb-16">
        <p class="section-label">The Problem</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-slate mb-4">
          Sound familiar?
        </h2>
        <p class="text-slate/60 max-w-xl mx-auto">
          Every seller hits the same walls as the business grows. We know exactly how to break through them.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {problems.map(block => (
          <div class="bg-white rounded-2xl p-8 border border-stone shadow-sm">
            <div class="text-sage mb-6" set:html={block.icon}></div>
            <h3 class="font-heading font-bold text-xl text-slate mb-4">{block.title}</h3>
            <div class="space-y-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-slate/40 mb-1">Problem</p>
                <p class="text-sm text-slate/70 leading-relaxed">{block.problem}</p>
              </div>
              <div class="border-t border-stone pt-4">
                <p class="text-xs font-semibold uppercase tracking-wider text-sage mb-1">Solution</p>
                <p class="text-sm text-slate/70 leading-relaxed">{block.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section class="bg-stone py-20 md:py-28" id="services">
    <div class="container-site">
      <div class="text-center mb-16">
        <p class="section-label">What We Offer</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-slate mb-4">Three Ways We Can Help</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-cream rounded-2xl p-8 border border-stone flex flex-col">
            <div class="mb-4">
              <span class={`inline-block text-xs font-bold px-3 py-1 rounded-full mb-3 ${
                svc.tier === 'Discover' ? 'bg-sage/10 text-sage' :
                svc.tier === 'Automate' ? 'bg-amber/10 text-amber' :
                'bg-slate/10 text-slate'
              }`}>
                {svc.badge}
              </span>
              <h3 class="font-heading font-bold text-2xl text-slate">{svc.tier}</h3>
              <div class="mt-1">
                <span class="font-heading font-bold text-xl text-slate">{svc.price}</span>
                <span class="text-sm text-slate/50 ml-2">· {svc.duration}</span>
              </div>
            </div>

            <p class="text-sm text-slate/60 mb-6 leading-relaxed">{svc.tagline}</p>

            <ul class="space-y-2 mb-8 flex-1">
              {svc.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-slate/70">
                  <svg class="w-4 h-4 text-sage mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>

            <a href={svc.href} class={`w-full text-center py-3 rounded-lg font-semibold text-sm transition-colors ${
              svc.tier === 'Automate'
                ? 'btn-primary w-full'
                : 'border-2 border-sage text-sage hover:bg-sage hover:text-white w-full block'
            }`}>
              Learn More →
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-slate/50 mt-8">
        Not sure which tier fits? <a href="/contact" class="text-sage underline hover:text-sage-dark">Book a free call and we'll tell you straight →</a>
      </p>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-site">
      <div class="text-center mb-16">
        <p class="section-label">Social Proof</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-slate">What Sellers Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white rounded-2xl p-8 border border-stone shadow-sm">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber fill-amber" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <blockquote class="text-slate/80 text-sm leading-relaxed mb-6 italic">
              "{t.quote}"
            </blockquote>
            <div>
              <p class="font-semibold text-sm text-slate">{t.author}</p>
              <p class="text-xs text-slate/50">{t.role}, {t.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY AGENTLE ===== -->
  <section class="bg-slate py-20 md:py-28 text-pearl">
    <div class="container-site max-w-3xl text-center">
      <p class="section-label text-amber/70">Why Agentle</p>
      <h2 class="font-heading font-bold text-3xl md:text-4xl mb-8">Not Just Another Automation Firm</h2>
      <p class="text-pearl/70 text-lg leading-relaxed mb-10">
        We don't sell you software and disappear. We build your automations, test them in our sandbox,
        hand them over live, and stay on call until they run smoothly.
        <strong class="text-pearl"> Our name is on the system — that's the guarantee.</strong>
      </p>
      <a href="/contact" class="btn-primary text-base">
        Book a Discovery Call →
      </a>
    </div>
  </section>

  <!-- ===== BLOG TEASER ===== -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-site">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="section-label">From the Blog</p>
          <h2 class="font-heading font-bold text-3xl text-slate">Practical Automation Insights</h2>
        </div>
        <a href="/blog" class="text-sm text-sage font-medium hover:text-sage-dark transition-colors hidden sm:block">View all posts →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {blogPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block bg-white rounded-2xl overflow-hidden border border-stone shadow-sm hover:shadow-md transition-shadow">
            <div class="bg-stone h-40 flex items-center justify-center">
              <span class="text-xs font-semibold px-3 py-1 bg-sage/10 text-sage rounded-full">{post.tag}</span>
            </div>
            <div class="p-6">
              <p class="text-xs text-slate/40 mb-2">{post.date} · {post.readTime}</p>
              <h3 class="font-heading font-bold text-lg text-slate mb-2 group-hover:text-sage transition-colors">{post.title}</h3>
              <p class="text-sm text-slate/60 leading-relaxed">{post.excerpt}</p>
              <p class="text-sm text-sage font-medium mt-4">Read →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="bg-sage py-20 md:py-28">
    <div class="container-site text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-pearl mb-6">
        Ready to Stop Doing Busywork?
      </h2>
      <p class="text-pearl/80 text-lg max-w-xl mx-auto mb-10">
        Tell us where you're stuck. We'll tell you if we can help — and give you a straight answer within 24 hours.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
        <a href="/contact" class="btn-primary text-base">
          Book a 20-Minute Discovery Call →
        </a>
      </div>
      <p class="text-sm text-pearl/50">
        or email us directly: <a href="mailto:hello@agentleconsulting.com" class="underline hover:text-pearl/70">hello@agentleconsulting.com</a>
      </p>
    </div>
  </section>
</Layout>
