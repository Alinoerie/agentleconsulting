---
// GDPR-compliant cookie consent banner
---

<div id="cookie-consent"
     class="fixed bottom-0 left-0 right-0 z-50 bg-slate text-pearl shadow-2xl transform translate-y-full transition-transform duration-500"
     aria-live="polite">
  <div class="container-site py-6">
    <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-12">
      <div class="flex-1">
        <p class="text-sm text-pearl/80 leading-relaxed">
          We use cookies to improve your experience and analyze site traffic.
          By clicking "Accept", you consent to our use of cookies.
          <a href="/legal/cookies" class="underline text-sage hover:text-sage-light ml-1">Learn more</a>
        </p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <button id="cookie-accept"
                class="btn-primary text-sm py-2.5 px-5 cursor-pointer">
          Accept All
        </button>
        <button id="cookie-reject"
                class="text-sm text-pearl/60 hover:text-pearl px-3 py-2 cursor-pointer transition-colors">
          Reject
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-consent');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  function getCookie(name) {
    const match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/[.+*]/g, '\\$&') + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function setCookie(name, value, days) {
    const expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/; SameSite=Lax`;
  }

  // Show banner only if no preference stored
  if (!getCookie('cookie_consent')) {
    // Small delay so it doesn't flash on load
    setTimeout(() => {
      banner?.classList.remove('translate-y-full');
    }, 800);
  }

  acceptBtn?.addEventListener('click', () => {
    setCookie('cookie_consent', 'accepted', 365);
    banner?.classList.add('translate-y-full');
    // Enable GA4
    if (typeof gtag !== 'undefined') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  });

  rejectBtn?.addEventListener('click', () => {
    setCookie('cookie_consent', 'rejected', 365);
    banner?.classList.add('translate-y-full');
  });
</script>
