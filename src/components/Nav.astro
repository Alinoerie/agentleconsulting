---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Blog', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-stone">
  <div class="container-site">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="AgentleConsulting Home">
        <!-- Gentle Signal "a" icon -->
        <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 28C6 28 12 8 22 10C32 12 30 22 30 22C30 22 28 14 22 14C16 14 18 22 18 22"
                stroke="#6B9E78" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="26" cy="10" r="3" fill="#D4956A"/>
        </svg>
        <span class="font-heading font-bold text-lg text-slate hidden sm:block">AgentleConsulting</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors duration-200',
              currentPath.startsWith(link.href)
                ? 'text-sage font-semibold'
                : 'text-slate/70 hover:text-sage'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a href="/contact" class="btn-primary text-sm py-2.5 px-5">
        Book a Call
      </a>
    </nav>
  </div>
</header>
